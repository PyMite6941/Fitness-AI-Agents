.env
__pycache__/
*.pyc
.venv/

# NOTE: do NOT gitignore bots.py here. huggingface_hub upload_folder and
# `huggingface-cli upload` both honor THIS .gitignore, so ignoring bots.py here
# silently drops it from the Space -> ModuleNotFoundError at runtime. The
# "keep it out of the main repo" rule lives in the repo-root .gitignore instead
# (as `huggingface_space/bots.py`), which the uploader never reads.
