# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://yourproject.supabase.co
# Project Settings → API → service_role key (NOT anon key — server needs full access)
SUPABASE_KEY=your_supabase_service_role_key

# ── Clerk ────────────────────────────────────────────────────────────────────
# Dashboard → API Keys → JWKS URL  (e.g. https://happy-cat-42.clerk.accounts.dev/.well-known/jwks.json)
CLERK_JWKS_URL=https://yourclerk.clerk.accounts.dev/.well-known/jwks.json
# Same base URL without the path  (used for JWT issuer validation)
CLERK_ISSUER_URL=https://yourclerk.clerk.accounts.dev

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated — must include every origin that the browser calls from
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ── OAuth CSRF protection ─────────────────────────────────────────────────────
# Run: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_STATE_SECRET=change_me_to_a_random_32_byte_hex_string

# ── URLs ─────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000        # or https://your-app.onrender.com
FRONTEND_URL=http://localhost:5173       # or https://your-app.vercel.app

# ── Strava ───────────────────────────────────────────────────────────────────
# Register at https://www.strava.com/settings/api
# Callback URL to set in Strava: {BACKEND_URL}/integrations/strava/callback
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# ── Fitbit / Google Health API ───────────────────────────────────────────────
# Fitbit Web API was deprecated. Register at https://console.cloud.google.com:
#   1. Create a project → Enable "Google Health API"
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
#   3. Add authorized redirect URI: {BACKEND_URL}/integrations/fitbit/callback
GOOGLE_HEALTH_CLIENT_ID=your_google_health_client_id
GOOGLE_HEALTH_CLIENT_SECRET=your_google_health_client_secret

# ── AI model providers ────────────────────────────────────────────────────────
# At least one required for /analyze to work — both is recommended for fallback
OPENROUTER_API_KEY=your_openrouter_key   # https://openrouter.ai/keys
GROQ_API_KEY=your_groq_key              # https://console.groq.com/keys
